datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  CUSTOMER
  OWNER
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  passwordHash       String
  name               String
  phone              String?  @unique
  role               UserRole @default(CUSTOMER)
  allergens          String[] @default([])
  dietaryPreferences String[] @default([])
  allergenAsked      Boolean  @default(false)
  restaurants        Restaurant[]
  orders             Order[]
  addresses          Address[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Restaurant {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  imageUrl      String?
  houseNumber   String
  street        String
  city          String
  postcode      String
  rating        Float?
  deliveryZones Json?
  pollToken     String?  @unique
  menus         Menu[]
  orders        Order[]
  blacklist     Blacklist[]
  owner         User?    @relation(fields: [ownerId], references: [id])
  ownerId       String?
  isBusy                Boolean  @default(false)
  busyExtraMinutes      Int      @default(15)
  defaultDeliveryMinutes Int     @default(30)
  acceptingOrders       Boolean  @default(true)
  whatsappPhone    String?  @unique
  voicePhone       String?  @unique
  twilioPhoneSid   String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isActive      Boolean  @default(false)
}

model Menu {
  id           String     @id @default(uuid())
  name         String
  description  String?
  imageUrl     String?
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  foods        Food[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Food {
  id          String       @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  basePrice   Float
  allergens   String[]     @default([])
  dietTags    String[]     @default([])
  isAvailable Boolean      @default(true)
  menu        Menu         @relation(fields: [menuId], references: [id], onDelete: Cascade)
  menuId      String
  options     FoodOption[]
  orderItems  OrderItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model FoodOption {
  id          String         @id @default(uuid())
  title       String
  multiple    Boolean        @default(false)
  isAvailable Boolean        @default(true)
  food        Food           @relation(fields: [foodId], references: [id], onDelete: Cascade)
  foodId      String
  choices     OptionChoice[]
}

model OptionChoice {
  id          String     @id @default(uuid())
  label       String
  extraPrice  Float      @default(0)
  isAvailable Boolean    @default(true)
  isStandard  Boolean    @default(false)
  option      FoodOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  optionId    String
}

model Order {
  id           String      @id @default(uuid())
  customer     String
  phone        String
  address      Json
  status       String      @default("pending")
  etaMinutes     Int?
  acknowledgedAt DateTime?
  items          OrderItem[]
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  user         User?       @relation(fields: [userId], references: [id])
  notes        String?
  userId       String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  food      Food?    @relation(fields: [foodId], references: [id], onDelete: SetNull)
  foodId    String?
  foodName  String?
  basePrice Decimal?
  quantity  Int
  selected  Json?
}

model Blacklist {
  id            String    @id @default(uuid())
  phone         String
  reason        String?
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId  String
  attemptCount  Int       @default(0)
  lastAttemptAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([phone, restaurantId])
}

model WhatsAppProfile {
  id                 String   @id @default(uuid())
  phone              String   @unique
  name               String?
  allergens          String[] @default([])
  dietaryPreferences String[] @default([])
  allergenAsked      Boolean  @default(false)
  addresses          Address[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Address {
  id                String   @id @default(uuid())
  userId            String?
  whatsappProfileId String?
  label             String?
  houseNumber       String
  street            String
  city              String
  postcode          String
  notes             String?
  isDefault         Boolean  @default(false)
  user              User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappProfile   WhatsAppProfile? @relation(fields: [whatsappProfileId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([whatsappProfileId])
}
